generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Post {
  id              String   @id @db.VarChar(64)
  authorId        String   @map("author_id") @db.VarChar(64)
  inReplyToPostId String?  @map("in_reply_to_post_id") @db.VarChar(64)
  body            String   @db.VarChar(280)
  visibility      String   @default("public") @db.VarChar(16)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([authorId, createdAt], map: "posts_posts_author_created_idx")
  @@map("posts_posts")
}

model Like {
  id        String   @id @db.VarChar(64)
  postId    String   @map("post_id") @db.VarChar(64)
  userId    String   @map("user_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId], map: "posts_likes_post_user_key")
  @@map("posts_likes")
}

model Repost {
  id        String   @id @db.VarChar(64)
  postId    String   @map("post_id") @db.VarChar(64)
  userId    String   @map("user_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([postId, userId], map: "posts_reposts_post_user_key")
  @@map("posts_reposts")
}

model PostMedia {
  id        String @id @db.VarChar(64)
  postId    String @map("post_id") @db.VarChar(64)
  assetId   String @map("asset_id") @db.VarChar(64)
  sortOrder Int    @map("sort_order")

  @@unique([postId, assetId], map: "posts_post_media_post_asset_key")
  @@map("posts_post_media")
}

model OutboxEvent {
  id            String    @id @db.VarChar(64)
  aggregateType String    @map("aggregate_type") @db.VarChar(32)
  aggregateId   String    @map("aggregate_id") @db.VarChar(64)
  eventType     String    @map("event_type") @db.VarChar(96)
  payload       Json
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("posts_outbox")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Follow {
  id         String   @id @db.VarChar(64)
  followerId String   @map("follower_id") @db.VarChar(64)
  followeeId String   @map("followee_id") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([followerId, followeeId], map: "graph_follows_follower_followee_key")
  @@map("graph_follows")
}

model Block {
  id        String   @id @db.VarChar(64)
  blockerId String   @map("blocker_id") @db.VarChar(64)
  blockedId String   @map("blocked_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([blockerId, blockedId], map: "graph_blocks_blocker_blocked_key")
  @@map("graph_blocks")
}

model Mute {
  id        String   @id @db.VarChar(64)
  muterId   String   @map("muter_id") @db.VarChar(64)
  mutedId   String   @map("muted_id") @db.VarChar(64)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([muterId, mutedId], map: "graph_mutes_muter_muted_key")
  @@map("graph_mutes")
}

model OutboxEvent {
  id            String    @id @db.VarChar(64)
  aggregateType String    @map("aggregate_type") @db.VarChar(32)
  aggregateId   String    @map("aggregate_id") @db.VarChar(64)
  eventType     String    @map("event_type") @db.VarChar(96)
  payload       Json
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("graph_outbox")
}

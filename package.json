{
  "name": "chirper",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:generate": "npm run prisma:generate -w @chirper/identity && npm run prisma:generate -w @chirper/profile && npm run prisma:generate -w @chirper/posts && npm run prisma:generate -w @chirper/graph && npm run prisma:generate -w @chirper/timeline && npm run prisma:generate -w @chirper/notifications && npm run prisma:generate -w @chirper/media",
    "build": "npm run prisma:generate && npm run build --workspaces --if-present",
    "typecheck": "npm run prisma:generate && npm run typecheck --workspaces --if-present",
    "check:boundaries": "node ./scripts/check-table-ownership.mjs",
    "check": "npm run check:boundaries && npm run typecheck",
    "db:identity:info": "node ./scripts/flyway-run.mjs --service identity --command info",
    "db:identity:migrate": "node ./scripts/flyway-run.mjs --service identity --command migrate",
    "db:identity:validate": "node ./scripts/flyway-run.mjs --service identity --command validate",
    "db:identity:seed:demo": "node ./scripts/sql-file-run.mjs --service identity --file db/seeds/demo.sql",
    "db:profile:info": "node ./scripts/flyway-run.mjs --service profile --command info",
    "db:profile:migrate": "node ./scripts/flyway-run.mjs --service profile --command migrate",
    "db:profile:validate": "node ./scripts/flyway-run.mjs --service profile --command validate",
    "db:profile:seed:demo": "node ./scripts/sql-file-run.mjs --service profile --file db/seeds/demo.sql",
    "db:posts:info": "node ./scripts/flyway-run.mjs --service posts --command info",
    "db:posts:migrate": "node ./scripts/flyway-run.mjs --service posts --command migrate",
    "db:posts:validate": "node ./scripts/flyway-run.mjs --service posts --command validate",
    "db:posts:seed:demo": "node ./scripts/sql-file-run.mjs --service posts --file db/seeds/demo.sql",
    "db:graph:info": "node ./scripts/flyway-run.mjs --service graph --command info",
    "db:graph:migrate": "node ./scripts/flyway-run.mjs --service graph --command migrate",
    "db:graph:validate": "node ./scripts/flyway-run.mjs --service graph --command validate",
    "db:graph:seed:demo": "node ./scripts/sql-file-run.mjs --service graph --file db/seeds/demo.sql",
    "db:timeline:info": "node ./scripts/flyway-run.mjs --service timeline --command info",
    "db:timeline:migrate": "node ./scripts/flyway-run.mjs --service timeline --command migrate",
    "db:timeline:validate": "node ./scripts/flyway-run.mjs --service timeline --command validate",
    "db:timeline:seed:demo": "node ./scripts/sql-file-run.mjs --service timeline --file db/seeds/demo.sql",
    "db:notifications:info": "node ./scripts/flyway-run.mjs --service notifications --command info",
    "db:notifications:migrate": "node ./scripts/flyway-run.mjs --service notifications --command migrate",
    "db:notifications:validate": "node ./scripts/flyway-run.mjs --service notifications --command validate",
    "db:notifications:seed:demo": "node ./scripts/sql-file-run.mjs --service notifications --file db/seeds/demo.sql",
    "db:media:info": "node ./scripts/flyway-run.mjs --service media --command info",
    "db:media:migrate": "node ./scripts/flyway-run.mjs --service media --command migrate",
    "db:media:validate": "node ./scripts/flyway-run.mjs --service media --command validate",
    "db:media:seed:demo": "node ./scripts/sql-file-run.mjs --service media --file db/seeds/demo.sql",
    "db:seed:demo": "npm run db:identity:seed:demo && npm run db:media:seed:demo && npm run db:profile:seed:demo && npm run db:posts:seed:demo && npm run db:graph:seed:demo && npm run db:timeline:seed:demo && npm run db:notifications:seed:demo",
    "dev:web": "npm run dev -w @chirper/web",
    "dev:bff": "npm run dev -w @chirper/bff",
    "dev:identity": "npm run dev -w @chirper/identity",
    "dev:profile": "npm run dev -w @chirper/profile",
    "dev:posts": "npm run dev -w @chirper/posts",
    "dev:graph": "npm run dev -w @chirper/graph",
    "dev:timeline": "npm run dev -w @chirper/timeline",
    "dev:notifications": "npm run dev -w @chirper/notifications",
    "dev:media": "npm run dev -w @chirper/media",
    "dev:realtime": "npm run dev -w @chirper/realtime"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "mysql2": "^3.22.0",
    "mysql2": "^3.15.3",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}

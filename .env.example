# Root-level example values. Copy the relevant ones into each workspace-specific .env file.

WEB_PORT=3000
BFF_PORT=4000

IDENTITY_HTTP_PORT=4001
IDENTITY_GRPC_BIND_URL=0.0.0.0:50051
IDENTITY_GRPC_URL=127.0.0.1:50051
IDENTITY_DATABASE_URL=mysql://app_user:secret@your-rds-host:3306/chirper

PROFILE_HTTP_PORT=4002
PROFILE_GRPC_BIND_URL=0.0.0.0:50052
PROFILE_GRPC_URL=127.0.0.1:50052
PROFILE_DATABASE_URL=mysql://app_user:secret@your-rds-host:3306/chirper

NEXT_PUBLIC_BFF_URL=http://localhost:4000
BFF_INTERNAL_URL=http://localhost:4000
BFF_PUBLIC_URL=http://localhost:4000
KAFKA_BROKERS=127.0.0.1:29092
KAFKA_POSTS_TOPIC=chirper.posts.events.v1
KAFKA_GRAPH_TOPIC=chirper.graph.events.v1
REDIS_URL=redis://localhost:6379

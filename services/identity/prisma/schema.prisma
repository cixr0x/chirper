generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @db.VarChar(64)
  handle      String   @unique(map: "ident_users_handle_key") @db.VarChar(32)
  displayName String   @map("display_name") @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("ident_users")
}

model Credential {
  id           String   @id @db.VarChar(64)
  userId       String   @map("user_id") @db.VarChar(64)
  provider     String   @db.VarChar(32)
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId], map: "ident_credentials_user_id_idx")
  @@map("ident_credentials")
}

model Session {
  id               String    @id @db.VarChar(64)
  userId           String    @map("user_id") @db.VarChar(64)
  sessionTokenHash String    @unique(map: "ident_sessions_refresh_token_key") @map("refresh_token") @db.VarChar(255)
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastSeenAt       DateTime? @map("last_seen_at")

  @@index([userId], map: "ident_sessions_user_id_idx")
  @@map("ident_sessions")
}

model PasswordReset {
  id             String    @id @db.VarChar(64)
  userId         String    @map("user_id") @db.VarChar(64)
  resetTokenHash String    @unique(map: "ident_password_resets_reset_token_key") @map("reset_token_hash") @db.VarChar(255)
  expiresAt      DateTime  @map("expires_at")
  consumedAt     DateTime? @map("consumed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([userId], map: "ident_password_resets_user_id_idx")
  @@index([expiresAt], map: "ident_password_resets_expires_at_idx")
  @@map("ident_password_resets")
}

model OutboxEvent {
  id            String    @id @db.VarChar(64)
  aggregateType String    @map("aggregate_type") @db.VarChar(32)
  aggregateId   String    @map("aggregate_id") @db.VarChar(64)
  eventType     String    @map("event_type") @db.VarChar(96)
  payload       Json
  publishedAt   DateTime? @map("published_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([publishedAt], map: "ident_outbox_published_at_idx")
  @@map("ident_outbox")
}
